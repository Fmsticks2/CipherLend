{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:backend": "tsx watch backend/src/server.ts",
    "dev:full": "npm run dev & npm run dev:backend",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && tsc -p backend/tsconfig.json --noEmit",
    "typecheck": "tsc --noEmit && tsc -p backend/tsconfig.json --noEmit",
    "compile": "hardhat --config hardhat.config.cjs compile",
    "test": "hardhat --config hardhat.config.cjs test",
    "deploy:helium": "hardhat --config hardhat.config.cjs run scripts/deploy.ts --network fhenixHelium"
  },
  "dependencies": {
    "@cofhe/sdk": "^0.4.0",
    "@openzeppelin/contracts": "5.0.2",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.95.2",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "ethers": "^6.15.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "viem": "^2.47.6",
    "vite": "^6.2.0",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@fhenixprotocol/contracts": "^0.3.1",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "fhenix-hardhat-network": "^0.3.2",
    "fhenix-hardhat-plugin": "^0.3.2",
    "hardhat": "^2.22.18",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
